APP_ENV=develop

LOGGER_DEBUG=true

HTTP_SERVER_HOST=0.0.0.0
HTTP_SERVER_PORT=8080

DATABASE_URL=postgres://repin:repin@localhost:5432/repin?sslmode=disable
DATABASE_SCHEMA=public

MIGRATIONS_DIR=migrations
MIGRATIONS_TABLE=schema_migrations

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_CHANNEL=allrpn
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_REFRESH_INTERVAL=6h

# Optional proxy for all outbound traffic: Telegram (sync, bot, worker) and
# OpenRouter. MTProto is tunnelled with CONNECT, so the proxy must allow it on
# port 443. socks5:// is also accepted.
# e.g. http://user:password@host:3128
PROXY_URL=

# SEO metadata generation. Without a key the worker skips seo jobs and the
# columns stay empty; everything else keeps working.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini
OPENROUTER_TIMEOUT=90s
OPENROUTER_MAX_RETRIES=2

# Background worker: media downloads and SEO generation.
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL=2s
# Must outlast the slowest job (a large video download).
WORKER_JOB_LEASE=30m

# Where to duplicate the channel avatar as favicon.jpg for the front.
FAVICON_DIR=../front/public/favicon

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=repin
