POSTGRES_USER=repin
POSTGRES_PASSWORD=repin
POSTGRES_DB=repin

# Only compose reads this file, so these point at service names rather than
# localhost. Both compose and the app's .env reader expand ${...}, so the
# credentials above stay the single source of truth.
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?sslmode=disable

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=repin

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_CHANNEL=allrpn
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_REFRESH_INTERVAL=6h

# Optional proxy for all outbound traffic: Telegram (sync, bot, worker) and
# OpenRouter. MTProto is tunnelled with CONNECT, so the proxy must allow it on
# port 443. socks5:// is also accepted.
# e.g. http://user:password@host:3128
PROXY_URL=

# SEO metadata generation. Without a key the worker skips seo jobs and the
# columns stay empty; everything else keeps working.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini

# How many jobs the worker runs at once.
WORKER_CONCURRENCY=2

# Public origin of the site, no trailing slash. Drives canonical links (read at
# runtime by the SSR server) and the OpenRouter HTTP-Referer header. Leave empty
# to skip canonical links entirely.
PUBLIC_SITE_URL=http://localhost:3000

# Baked into the client bundle at build time — changing it requires
# `docker compose build web`, not just a restart.
PUBLIC_API_URL=http://localhost:8080
